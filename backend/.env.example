# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Models
ROUTER_MODEL=claude-haiku-4-5-20251001
AGENT_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=voyage-large-2-instruct

# Embeddings (Voyage AI replaces OpenAI for embeddings)
VOYAGE_API_KEY=your_voyage_api_key_here

# Vector store (Supabase)
SUPABASE_URL=https://your-project.supabase.co

# Database (defaults match docker-compose.yml)
DATABASE_URL=postgresql://concierge:concierge@localhost:5432/concierge

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS — comma-separated origins. Use http://localhost:3000 for local dev.
CORS_ORIGINS=http://localhost:3000
