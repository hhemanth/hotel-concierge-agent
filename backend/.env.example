# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Models
ROUTER_MODEL=claude-sonnet-4-6
AGENT_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=voyage-large-2-instruct

# Embeddings (Voyage AI replaces OpenAI for embeddings)
VOYAGE_API_KEY=your_voyage_api_key_here

# Vector store — Supabase REST API URL (optional; only needed if using supabase-py client)
# The agent uses DATABASE_URL (psycopg direct connection) for all pgvector queries.
SUPABASE_URL=https://your-project.supabase.co

# Database (defaults match docker-compose.yml; in prod use the Supabase connection string)
DATABASE_URL=postgresql://concierge:concierge@localhost:5432/concierge

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS — comma-separated origins. Use http://localhost:3000 for local dev.
CORS_ORIGINS=http://localhost:3000
